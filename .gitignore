# Создать файл .gitignore (если нет)
cat > .gitignore << EOF
# Dependencies
node_modules/
.pnpm-store/

# Next.js build output
.next/
out/
build/
dist/

# Production builds
*.next

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Prisma
prisma/*.db
prisma/*.db-journal

# Temporary files
*.tmp
*.temp
EOF



